[gd_scene format=3 uid="uid://dy7ufjt2a4bnl"]

[sub_resource type="GDScript" id="GDScript_y4gye"]
script/source = "extends Control

var presentation_screen = preload(\"res://screens/presentation_screen.tscn\")
var stend_screen = preload(\"res://screens/stend_screen.tscn\")

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass


func _on_button_presentation_pressed() -> void:
	GC.active_screen_node.get_child(0).queue_free()
	GC.active_screen_node.add_child(presentation_screen.instantiate())
	

func _on_button_stend_pressed() -> void:
	GC.active_screen_node.get_child(0).queue_free()
	GC.active_screen_node.add_child(stend_screen.instantiate())
"

